# Environment Variables Example
# Copy this file to .env and fill in your values

# Frontend API Configuration
REACT_APP_API_URL=https://gocabingo-backend-xxxxx.onrender.com

# Backend Configuration
PORT=3000
NODE_ENV=development

# Email Configuration (for OTP/notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@gocabingo.com

# Database (optional - for MongoDB upgrade)
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/gocabingo

# Payment Gateway (optional - for real payments)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_SECRET=xxxxx

# JWT Secret (for production authentication)
JWT_SECRET=your-super-secret-key-here

# CORS Configuration
ALLOWED_ORIGINS=https://gocabingo-xxxxx.netlify.app,http://localhost:3000

# Session Configuration
SESSION_SECRET=another-super-secret-key

# File Upload (optional)
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# Features
ENABLE_EMAIL_VERIFICATION=false
ENABLE_SMS_OTP=false
ENABLE_PAYMENT_GATEWAY=false
